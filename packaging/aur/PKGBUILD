source_x86_64=("${url}/releases/download/v${pkgver}/gospeed_${pkgver}_linux_amd64.tar.gz")
source_aarch64=("${url}/releases/download/v${pkgver}/gospeed_${pkgver}_linux_arm64.tar.gz")
